{
  "name": "jobpilot",
  "private": true,
  "version": "1.0.0",
  "description": "JobPilot — AI Job Copilot SaaS for Indian job seekers",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "start": "turbo run start",
    "web": "pnpm --filter @jobpilot/web dev",
    "worker": "pnpm --filter @jobpilot/worker dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
