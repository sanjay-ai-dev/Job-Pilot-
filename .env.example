# ─── JobPilot environment ────────────────────────────────────────────────
# Copy to .env and fill in. The app runs in MOCK mode with NO keys set.
# When MOCK_MODE=true (default when keys are absent), all external services
# (Supabase, Anthropic, Voyage, JSearch, Adzuna, Apollo, Resend, Razorpay)
# are replaced by deterministic mock adapters + seeded data.

MOCK_MODE=true

# ─── Supabase (Mumbai region) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Queue ───────────────────────────────────────────────────────────────
REDIS_URL=

# ─── LLM + embeddings ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ─── Job source APIs ─────────────────────────────────────────────────────
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ─── Recruiter contacts ──────────────────────────────────────────────────
APOLLO_API_KEY=

# ─── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ─── Payments ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Optional scraper sources (OFF by default, per §5) ───────────────────
ENABLE_APIFY_SOURCES=false
APIFY_TOKEN=

# ─── Budget guards ───────────────────────────────────────────────────────
MAX_JSEARCH_CALLS_PER_DAY=200
MAX_ADZUNA_CALLS_PER_DAY=500

# ─── Admin ───────────────────────────────────────────────────────────────
ADMIN_EMAILS=founder@jobpilot.in
